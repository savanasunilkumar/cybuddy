NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Microsoft OAuth (required for /auth/login and /auth/callback)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=

# Development auth bypass (set false to disable)
ENABLE_DEV_AUTH_BYPASS=true

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=24h

# Canvas
CANVAS_BASE_URL=https://canvas.iastate.edu
CANVAS_API_KEY=

# Workday
WORKDAY_BASE_URL=
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=

# CyRide (live public feed)
CYRIDE_LIVE_BASE_URL=https://www.mycyride.com
CYRIDE_CUSTOMER_ID=187

# Cloudflare AI proxy (Kimi K2.6 via originx-ai-proxy worker)
AI_PROXY_URL=
AI_PROXY_TOKEN=
AI_MODEL=@cf/moonshotai/kimi-k2.6

# Redis (optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
