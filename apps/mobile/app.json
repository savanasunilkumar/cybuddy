{
  "expo": {
    "name": "Cybuddy",
    "slug": "cypilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cypilot.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Cybuddy uses the camera so Cy can describe what is in front of you out loud.",
        "NSMicrophoneUsageDescription": "Cybuddy uses the microphone so you can talk to Cy hands-free.",
        "NSPhotoLibraryUsageDescription": "Cybuddy uses your photos when you ask Cy to describe an existing image.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "cypilot",
            "CFBundleURLSchemes": [
              "cypilot"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.cypilot.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "cypilot"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Cybuddy to use your location to set your trip starting point."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": false
          },
          "android": {
            "newArchEnabled": false
          }
        }
      ],
      "expo-audio",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Cybuddy uses the camera so Cy can describe what is in front of you out loud."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cybuddy uses the camera so Cy can describe what is in front of you out loud.",
          "microphonePermission": "Cybuddy uses the microphone so you can talk to Cy hands-free.",
          "recordAudioAndroid": false
        }
      ]
    ],
    "scheme": "cypilot",
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
